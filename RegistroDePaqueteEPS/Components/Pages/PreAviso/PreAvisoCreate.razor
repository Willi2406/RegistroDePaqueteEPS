@page "/preavisousuario/upsert/{PreavisoId:int}"
@using MudBlazor
@inject NavigationManager NavManager
@inject PreavisosService preavisosService
@rendermode InteractiveServer

<SectionContent SectionName="TituloPagina">
    <h1>PRE-AVISO</h1>
</SectionContent>

<div class="glass-container create-preaviso-view">

    <div class="header-actions">
        <a href="/preavisousuario" class="btn-back">
            <i class="bi bi-arrow-left-circle-fill icono-grande"></i>
        </a>
    </div>

    <div class="form-content">
        <h3 class="section-title">@Estado Preaviso</h3>

        <EditForm Model="Preaviso" OnValidSubmit="GuardarPreaviso">
            <DataAnnotationsValidator />

            <div class="form-grid">
                <div class="form-item">
                    <label>Tracking Number</label>
                    <input type="text" class="input-box"
                           @bind-value="Preaviso.NumeroTracking"
                           placeholder="Ej: 1Z999..." />
                    <ValidationMessage For="@(() => Preaviso.NumeroTracking)" />
                </div>

                <div class="form-item">
                    <label>Tienda</label>
                    <input type="text" class="input-box"
                           @bind-value="Preaviso.Tienda"
                           placeholder="Ej: Amazon, Shein" />
                    <ValidationMessage For="@(() => Preaviso.Tienda)" />
                </div>

                <div class="form-item">
                    <label>Transportista</label>
                    <select class="input-box" @bind="Preaviso.Transportista">
                        <option value="">Seleccione...</option>
                        <option value="Amazon Logistics">Amazon Logistics</option>
                        <option value="UPS">UPS</option>
                        <option value="FedEx">FedEx</option>
                        <option value="USPS">USPS</option>
                        <option value="DHL">DHL</option>
                        <option value="Lasership">Lasership</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>

                <div class="form-item">
                    <label>Contenido</label>
                    <input type="text" class="input-box"
                           @bind-value="Preaviso.Contenido"
                           placeholder="Ej: Ropa, Zapatos" />
                    <ValidationMessage For="@(() => Preaviso.Contenido)" />
                </div>

                <div class="form-item">
                    <label>Valor (USD)</label>
                    <input type="number" class="input-box"
                           @bind-value="Preaviso.Valor"
                           placeholder="0.00" step="0.01" />
                    <ValidationMessage For="@(() => Preaviso.Valor)" />
                </div>

                <div class="form-item">
                    <label>Factura (PDF/Imagen)</label>
                    <div class="file-upload-box input-box">
                        <i class="bi bi-cloud-upload"></i>
                        <span>Adjuntar Archivo</span>
                        <InputFile OnChange="ManejarArchivo" class="file-input-hidden" />
                    </div>
                </div>
            </div>

            <div class="action-buttons">
                <a href="/preavisousuario" class="btn-cancel">Cancelar</a>
                <button type="submit" class="btn-save">Guardar Pre-Aviso</button>
            </div>

        </EditForm>
    </div>

    <MudDialog @bind-IsVisible="dialogoVisible" Options="dialogOptions" Class="glass-dialog">
        <DialogContent>
            <div class="success-content">
                <div class="icon-circle">
                    <MudIcon Icon="@Icons.Material.Filled.Check" Class="check-icon" />
                </div>
                <h2 class="success-title">¡ÉXITO!</h2>
                <p class="success-message">El Pre-Aviso ha sido guardado correctamente.</p>
            </div>
        </DialogContent>
        <DialogActions>
            <div class="action-area">
                <MudButton OnClick="CerrarYRedirigir" Class="btn-mud-custom">Continuar</MudButton>
            </div>
        </DialogActions>
    </MudDialog>

</div>

@code {
    // 2. CORRECCIÓN DEL ERROR DE PROPIEDAD:
    // El nombre "PreavisoId" debe coincidir exactamente con la ruta {PreavisoId}
    [Parameter]
    public int PreavisoId { get; set; }

    public Preavisos Preaviso { get; set; } = new Preavisos();
    public string Estado { get; set; } = "Crear";

    // Variables para el diálogo
    private bool dialogoVisible = false;

    // Configuramos BackdropClick = false para que no se cierre clicando fuera (Forma nueva)
    private DialogOptions dialogOptions = new DialogOptions
    {
        BackdropClick = false,
        CloseOnEscapeKey = true,
        NoHeader = true
    };

    protected override async Task OnInitializedAsync()
    {
        if (PreavisoId > 0)
        {
            Estado = "Editar";
            Preaviso = await preavisosService.Buscar(PreavisoId);
        }
    }

    private async Task GuardarPreaviso()
    {
        var modificado = await preavisosService.Guardar(Preaviso);
        if (modificado)
        {
            // Mostramos el diálogo en lugar de navegar de inmediato
            dialogoVisible = true;
        }
    }

    private void CerrarYRedirigir()
    {
        dialogoVisible = false;
        NavManager.NavigateTo("/preavisousuario");
    }

    private void ManejarArchivo(InputFileChangeEventArgs e)
    {
        // Lógica de archivo
    }
}
